[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
	ignorecase = true
	precomposeunicode = true
[remote "origin"]
	url = https://git@github.com:chrisbautista/codespud.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "master"]
	remote = origin
	merge = refs/heads/master
	vscode-merge-base = origin/master
[pull]
	rebase = true
[branch "gitbutler/workspace"]
	vscode-merge-base = origin/master
[branch "claude/objective-elgamal-60e42c"]
	remote = origin
	merge = refs/heads/master
[extensions]
	worktreeConfig = true
[branch "gatsby5-upgrade"]
	vscode-merge-base = origin/master
[branch "gh-pages"]
	remote = origin
	merge = refs/heads/gh-pages
	vscode-merge-base = origin/gh-pages
